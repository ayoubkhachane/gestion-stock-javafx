<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.CategoriesController"
      spacing="15" style="-fx-padding: 25; -fx-background-color: #f0f2f5;">

    <Label text="🏷️ Gestion des Catégories" 
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="txtNomCat" promptText="Nom de la catégorie..." 
                   HBox.hgrow="ALWAYS"
                   style="-fx-background-radius: 8; -fx-padding: 10;"/>
        <Button text="➕ Ajouter" onAction="#ajouterCategorie"
                style="-fx-background-color: #00c853; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 10 20;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="✏️ Modifier" onAction="#modifierCategorie"
                style="-fx-background-color: #ff9800; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 10 20;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Button text="🗑️ Supprimer" onAction="#supprimerCategorie"
                style="-fx-background-color: #f44336; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 10 20;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>
    
    <TableView fx:id="tableCategories" VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 10; -fx-border-radius: 10;
                      -fx-border-color: #e0e0e0;">
        <columns>
            <TableColumn fx:id="colIdCat" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colNomCat" text="Nom Catégorie" prefWidth="300"/>
        </columns>
    </TableView>
    
    <Label fx:id="lblMessageCat" text="Prêt"
           style="-fx-text-fill: #9e9e9e;"/>

</VBox>