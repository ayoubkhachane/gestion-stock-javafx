<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController"
            style="-fx-background-color: #f0f2f5;">

    <!-- ========== TOP BAR ========== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" 
              style="-fx-background-color: linear-gradient(to right, #1a237e, #3949ab); -fx-padding: 15 25;">
            <Label text="📦 Gestion de Stock" 
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📊 Dashboard" onAction="#ouvrirDashboard"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 20;
                           -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="📄 Export PDF" onAction="#exporterPDF"
                    style="-fx-background-color: #ff5722; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 20;
                           -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="🏷️ Catégories" onAction="#ouvrirCategories"
                    style="-fx-background-color: #4caf50; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 20;
                           -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- ========== ALERTE STOCK BAS ========== -->
            <HBox fx:id="alertBox" visible="false" spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: linear-gradient(to right, #ff5252, #ff1744);
                         -fx-padding: 12 20; -fx-background-radius: 10;">
                <Label text="⚠️" style="-fx-font-size: 20px;"/>
                <Label fx:id="alertLabel" text="Alerte stock bas!"
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>

            <!-- ========== CONTENU PRINCIPAL ========== -->
            <HBox spacing="20" VBox.vgrow="ALWAYS">

                <!-- ========== PANNEAU GAUCHE : FORMULAIRE ========== -->
                <VBox spacing="12" style="-fx-background-color: white;
                           -fx-padding: 25; -fx-background-radius: 15;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);
                           -fx-min-width: 260; -fx-max-width: 260;">

                    <Label text="📝 Nouveau Produit" 
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>

                    <Region prefHeight="1" style="-fx-background-color: #e0e0e0;"/>

                    <GridPane vgap="10" hgap="8">
                        <Label text="Nom" GridPane.rowIndex="0" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtNom" promptText="Ex: Clavier" 
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"
                                   style="-fx-background-radius: 6; -fx-padding: 6;"/>

                        <Label text="Prix (DH)" GridPane.rowIndex="1" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtPrix" promptText="Ex: 150" 
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"
                                   style="-fx-background-radius: 6; -fx-padding: 6;"/>

                        <Label text="Quantité" GridPane.rowIndex="2" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtQuantite" promptText="Ex: 25" 
                                   GridPane.rowIndex="2" GridPane.columnIndex="1"
                                   style="-fx-background-radius: 6; -fx-padding: 6;"/>

                        <Label text="Seuil Min" GridPane.rowIndex="3" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <TextField fx:id="txtSeuil" promptText="Ex: 10" 
                                   GridPane.rowIndex="3" GridPane.columnIndex="1"
                                   style="-fx-background-radius: 6; -fx-padding: 6;"/>

                        <Label text="Catégorie" GridPane.rowIndex="4" GridPane.columnIndex="0"
                               style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                        <ComboBox fx:id="comboCat" promptText="Choisir..." 
                                  GridPane.rowIndex="4" GridPane.columnIndex="1"
                                  style="-fx-background-radius: 6; -fx-padding: 2;"/>
                    </GridPane>

                    <Region VBox.vgrow="ALWAYS"/>

                    <!-- Boutons CRUD -->
                    <VBox spacing="8">
                        <Button text="➕ Ajouter Produit" onAction="#ajouter" maxWidth="Infinity"
                                style="-fx-background-color: linear-gradient(to right, #00c853, #64dd17);
                                       -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <HBox spacing="8">
                            <Button text="✏️ Modifier" onAction="#modifier" prefWidth="110"
                                    style="-fx-background-color: #ff9800; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-padding: 10;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button text="🗑️ Supprimer" onAction="#supprimer" prefWidth="110"
                                    style="-fx-background-color: #f44336; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-padding: 10;
                                           -fx-background-radius: 8; -fx-cursor: hand;"/>
                        </HBox>
                        <Button text="🔄 Vider Champs" onAction="#vider" maxWidth="Infinity"
                                style="-fx-background-color: #9e9e9e; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 10;
                                       -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </VBox>

                </VBox>

                <!-- ========== PANNEAU DROIT : TABLEAU ========== -->
                <VBox spacing="12" HBox.hgrow="ALWAYS" 
                      style="-fx-background-color: white;
                             -fx-padding: 20; -fx-background-radius: 15;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);">

                    <!-- Barre de recherche -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtRecherche" promptText="🔍 Rechercher un produit..." 
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 20; -fx-padding: 8 15;
                                          -fx-background-color: #f5f5f5;"/>
                        <Button text="Rechercher" onAction="#rechercher"
                                style="-fx-background-color: #2196f3; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 8 18;
                                       -fx-background-radius: 20; -fx-cursor: hand;"/>
                        <Button text="🔄 Tout" onAction="#rafraichir"
                                style="-fx-background-color: #9c27b0; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-padding: 8 18;
                                       -fx-background-radius: 20; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- TableView -->
                    <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS"
                               style="-fx-background-radius: 8; -fx-border-radius: 8;
                                      -fx-border-color: #e0e0e0; -fx-border-width: 1;">
                        <columns>
                            <TableColumn fx:id="colId" text="#" prefWidth="35"/>
                            <TableColumn fx:id="colNom" text="Produit" prefWidth="120"/>
                            <TableColumn fx:id="colPrix" text="Prix" prefWidth="70"/>
                            <TableColumn fx:id="colQte" text="Qté" prefWidth="45"/>
                            <TableColumn fx:id="colSeuil" text="Seuil" prefWidth="50"/>
                            <TableColumn fx:id="colCat" text="Catégorie" prefWidth="95"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="75"/>
                        </columns>
                    </TableView>

                    <!-- Message en bas -->
                    <Label fx:id="lblMessage" text="Prêt"
                           style="-fx-text-fill: #9e9e9e; -fx-font-size: 11px;"/>

                </VBox>

            </HBox>

        </VBox>
    </center>
</BorderPane>